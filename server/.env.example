# ============================================================
# Roost - Backend Environment Variables
# Copy this to .env and fill in your values
# Or run: bash install.sh (from project root)
# ============================================================

NODE_ENV=development
PORT=3000

# --- Database Provider ---
# Must match frontend VITE_DB_PROVIDER
# Options: supabase-cloud | supabase-selfhosted | mongodb
DB_PROVIDER=supabase-cloud

# --- Supabase (required for supabase-cloud / supabase-selfhosted) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key

# For direct DB access (backups, migrations)
# SUPABASE_DB_PASSWORD=your-db-password
# DB_HOST=db.your-project.supabase.co
# DB_PORT=5432

# --- MongoDB (required for mongodb provider) ---
# DATABASE_URL=mongodb://localhost:27017/roost
# JWT_SECRET=your-jwt-secret-here

# --- AWS S3 / Storage ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT=  # For S3-compatible (MinIO, R2, etc.)
# AWS_BACKUP_ENDPOINT=  # Optional separate endpoint for backup bucket (defaults to S3_ENDPOINT)

# Backup bucket (optional)
# AWS_BACKUP_BUCKET=your-backup-bucket
# AWS_BACKUP_REGION=us-east-1

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=Roost

# --- Redis (optional) ---
# REDIS_URL=redis://localhost:6379

# --- Stripe Integration (optional) ---
# STRIPE_SECRET_KEY=sk_test_your-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# STRIPE_PRICE_ID=price_your-price-id

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
