# ============================================================
# Roost - Frontend Environment Variables
# Copy this to .env.local and fill in your values
# Or run: bash install.sh
# ============================================================

# --- App Configuration ---
VITE_APP_NAME="Roost"
VITE_APP_TAGLINE="Learn, Build, Grow Together"
VITE_APP_DESCRIPTION="A community platform for learning, building, and growing together."
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api

# --- Database Provider ---
# Options: supabase-cloud | supabase-selfhosted | mongodb
VITE_DB_PROVIDER=supabase-cloud

# --- Supabase (required for supabase-cloud / supabase-selfhosted) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# --- MongoDB (required for mongodb provider) ---
# VITE_DATABASE_URL=mongodb://localhost:27017/roost

# --- AWS S3 / Storage ---
VITE_AWS_REGION=us-east-1
VITE_AWS_S3_BUCKET=your-bucket-name

# --- Feature Flags ---
VITE_ENABLE_SIGNUP=true
VITE_STRIPE_ENABLED=false
VITE_ENABLE_SHOWCASE=true
VITE_ENABLE_LIVE_ROOM=true
VITE_ENABLE_ACTIVATIONS=false
VITE_ENABLE_LEADERBOARD=true

# --- Support ---
VITE_SUPPORT_EMAIL=
VITE_SUPPORT_URL=

# --- Debug ---
VITE_DEBUG_MODE=false
VITE_ENABLE_MOCK_DATA=false
