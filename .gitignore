dist/
build/
*.tsbuildinfo

# =============================================================================
# Environment files (contain secrets — NEVER commit these)
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
server/.env
server/src/.env

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
